# ── Convex ──────────────────────────────────────────────────────────────────
# Set automatically by `npx convex dev` during local development
NEXT_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud

# ── Application ──────────────────────────────────────────────────────────────
# The public URL of the deployed app
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Convex Auth (set on Convex side, NOT in Vercel) ───────────────────────────
# Set via: npx @convex-dev/auth generate-keys
# or manually in the Convex dashboard → Settings → Environment Variables
# JWT_PRIVATE_KEY=<generated>
# JWKS=<generated>
# SITE_URL=<your-app-url>
